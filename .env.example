PORT=3000
NODE_ENV=development
SEO_AGENT_HOST_PORT=8011

OPENAI_API_KEY=
GOOGLE_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=owner/repository

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@example.com

# Optional: recipient for scheduled scan reports (defaults to EMAIL_USER)
REPORT_EMAIL_TO=

# Daily scan at 09:00 UTC (cron syntax)
CRON_SCHEDULE=0 9 * * *

# Crawler limits (use 0 = crawl every discoverable same-origin page)
MAX_PAGES_PER_SCAN=25
CRAWL_WORKERS=12
CRAWL_MAX_DEPTH=4
CRAWL_TIMEOUT_MS=12000
BROKEN_LINK_CHECK_CAP=200
SLOW_PAGE_MS=3000

# SQLite path inside container
DB_PATH=/app/data/seo-agent.db
